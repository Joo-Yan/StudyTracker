generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Habit {
  id            String     @id @default(cuid())
  userId        String
  title         String
  description   String?
  icon          String?    @default("✓")
  color         String?    @default("#6366f1")
  frequencyType String     @default("daily") // daily | weekly | monthly
  frequencyDays Int[]      @default([]) // 0-6 for weekly
  timesPerPeriod Int?
  reminderTime  String?    // HH:MM
  startDate     DateTime   @default(now())
  isActive      Boolean    @default(true)
  tags          String[]   @default([])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  logs          HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      String   // YYYY-MM-DD
  completed Boolean  @default(true)
  note      String?
  loggedAt  DateTime @default(now())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
}

model Objective {
  id          String      @id @default(cuid())
  userId      String
  title       String
  description String?
  deadline    DateTime
  status      String      @default("active") // active | completed | overdue | archived
  tags        String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  keyResults  KeyResult[]
  tasks       OKRTask[]

  @@index([userId])
}

model KeyResult {
  id           String    @id @default(cuid())
  objectiveId  String
  title        String
  type         String    @default("percentage") // binary | numeric | percentage
  targetValue  Float     @default(100)
  currentValue Float     @default(0)
  unit         String?
  weight       Int       @default(3) // 1-5
  status       String    @default("not_started") // not_started | in_progress | completed
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  objective    Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  checkIns     CheckIn[]

  @@index([objectiveId])
}

model CheckIn {
  id          String    @id @default(cuid())
  keyResultId String
  value       Float
  note        String?
  date        DateTime  @default(now())
  keyResult   KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  @@index([keyResultId])
}

model OKRTask {
  id          String    @id @default(cuid())
  userId      String
  objectiveId String
  title       String
  status      String    @default("todo")
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  objective   Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  status      String       @default("active") // planning | active | paused | completed | archived
  color       String?      @default("#6366f1")
  tags        String[]     @default([])
  startDate   DateTime?
  targetDate  DateTime?
  linkedOkrId String?
  linkedIdeaId String?
  notes       String?      @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  milestones  Milestone[]
  logs        ProjectLog[]

  @@index([userId])
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  order       Int      @default(0)
  status      String   @default("pending") // pending | in_progress | completed
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([projectId])
}

model Task {
  id          String    @id @default(cuid())
  milestoneId String
  title       String
  status      String    @default("todo") // todo | doing | done
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
}

model ProjectLog {
  id        String   @id @default(cuid())
  projectId String
  content   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ContentItem {
  id            String    @id @default(cuid())
  userId        String
  title         String
  url           String?
  description   String?
  type          String    @default("article") // article | video | book | course | podcast | other
  tags          String[]  @default([])
  status        String    @default("want_to_learn") // want_to_learn | learning | completed | dropped
  priority      Int       @default(2) // 1=high 2=medium 3=low
  source        String?
  rating        Int?      // 1-5
  notes         String?
  estimatedTime Int?      // minutes
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  @@index([userId])
}

model Idea {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String?
  type            String   @default("project") // project | feature | experiment | thought | other
  tags            String[] @default([])
  status          String   @default("raw") // raw | evaluating | planned | in_progress | archived | dropped
  priority        Int      @default(2) // 1=high 2=medium 3=low
  linkedProjectId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model LifeCompass {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   String   @default("")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Todo {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  dueDate     DateTime?
  priority    Int       @default(2) // 1=high 2=medium 3=low
  completed   Boolean   @default(false)
  completedAt DateTime?
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, completed])
}
